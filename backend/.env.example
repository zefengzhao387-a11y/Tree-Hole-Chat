# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/diary.db

# Chroma 向量数据库路径
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 生产部署：允许的前端域名，逗号分隔
# CORS_ORIGINS=https://tree-hole-chat.vercel.app
# Vercel 预览部署（域名每次不同）：
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# JWT（生产环境务必改成随机长字符串）
# JWT_SECRET=change-me-in-production
